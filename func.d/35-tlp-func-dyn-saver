#!/bin/sh
# tlp-func-dyn-saver - Dynamic adjustments for power-saver profile
#
# Activates only in battery mode when the active profile is power-saver.
# Adjusts PLATFORM_PROFILE_ON_SAV, CPU_ENERGY_PERF_POLICY_ON_SAV and
# PCIE_ASPM_ON_SAV workload-dependently (low/med/high) using existing
# setter functions. Designed for install-and-forget usage (disabled by default).

# Requires: tlp-func-base, tlp-func-cpu, tlp-func-pm

# ============================================================================
# Helper functions
# ============================================================================

create_pidfile() {
    [ -n "$RUNDIR" ] || RUNDIR=/run/tlp
    mkdir -p "$RUNDIR"
    echo "$1" > "$RUNDIR/tlp-dyn-saver.pid"
}

remove_pidfile() {
    rm -f "$RUNDIR/tlp-dyn-saver.pid" 2>/dev/null || true
}

is_running() {
    [ -f "$RUNDIR/tlp-dyn-saver.pid" ] || return 1
    pid=$(cat "$RUNDIR/tlp-dyn-saver.pid")
    [ -n "$pid" ] || return 1
    kill -0 "$pid" 2>/dev/null
}

read_cpu_pct() {
    # read aggregate cpu utilization over $1 seconds
    # optimized: use head + set instead of 4 awk calls
    local sleep_sec=${1:-1}
    
    # Read first snapshot (all cpu time fields)
    set -- $(head -1 /proc/stat)
    shift  # skip "cpu" label
    local cpu1=0 idle1=$4
    for val in "$@"; do cpu1=$((cpu1 + val)); done
    
    sleep "$sleep_sec"
    
    # Read second snapshot (all cpu time fields)
    set -- $(head -1 /proc/stat)
    shift  # skip "cpu" label
    local cpu2=0 idle2=$4
    for val in "$@"; do cpu2=$((cpu2 + val)); done
    
    local cpu_delta=$((cpu2 - cpu1))
    local idle_delta=$((idle2 - idle1))
    
    if [ "$cpu_delta" -le 0 ]; then
        echo 0
        return
    fi
    
    local busy=$((cpu_delta - idle_delta))
    echo "$((busy * 100 / cpu_delta))"
}

get_lag_score() {
    # Calculate lag indicator using snapshot caching in temporary file
    # Returns a "lag score" 0-100 where lag score influences SAV profile parameters:
    #   0-35:  Low lag (idle/light load) → relax PLATFORM_PROFILE, CPU_PERF, PCIE_ASPM
    #  35-75:  Medium lag (normal work) → moderate PLATFORM_PROFILE, CPU_PERF, PCIE_ASPM
    #  75-100: High lag (heavy load) → maximize performance within SAV mode
    #
    # Note: Daemon only adjusts 3 parameters within the power-saver profile,
    # does NOT switch to different profile (performance, balanced, etc.)
    #
    # OPTIMIZATION: Uses file-based snapshot cache - 0% measurement overhead!
    # Reads current /proc/stat and compares with cached previous snapshot
    
    local cache_file="/run/tlp/lag_snapshot"
    mkdir -p /run/tlp 2>/dev/null
    
    # Read CURRENT snapshot (instantaneous, no sleep!)
    set -- $(head -1 /proc/stat)
    shift  # skip "cpu" label
    
    local cpu_total=0 current_idle=$4 current_iowait=$5
    for val in "$@"; do cpu_total=$((cpu_total + val)); done
    
    # Read CACHED previous snapshot (or create if missing)
    if [ -f "$cache_file" ]; then
        read last_cpu_time last_idle last_iowait < "$cache_file" 2>/dev/null
    fi
    [ -z "$last_cpu_time" ] && last_cpu_time=0
    [ -z "$last_idle" ] && last_idle=0
    [ -z "$last_iowait" ] && last_iowait=0
    
    # Save current snapshot for next call
    echo "$cpu_total $current_idle $current_iowait" > "$cache_file" 2>/dev/null
    
    # Calculate deltas since last snapshot
    local cpu_delta=$((cpu_total - last_cpu_time))
    local idle_delta=$((current_idle - last_idle))
    local iowait_delta=$((current_iowait - last_iowait))
    
    # Handle edge cases (first run or negative deltas from overflow)
    if [ "$cpu_delta" -le 0 ]; then
        echo 0
        return
    fi
    
    # Calculate CPU utilization percentage
    local busy_delta=$((cpu_delta - idle_delta))
    local cpu_pct=$((busy_delta * 100 / cpu_delta))
    
    # Calculate I/O-Wait percentage (separate metric for blocking)
    local iowait_pct=$((iowait_delta * 100 / cpu_delta))
    
    # Convert metrics to lag_score (0-100)
    # Base: CPU pct mapping
    # Bonus: I/O-Wait contribution (indicates blocking, responsive lag)
    
    local lag_score=0
    
    if [ "$cpu_pct" -lt 40 ]; then
        lag_score=$((cpu_pct / 2))  # 0-20 points
    elif [ "$cpu_pct" -lt 70 ]; then
        lag_score=$((20 + (cpu_pct - 40) * 4 / 3))  # 20-60 points
    elif [ "$cpu_pct" -lt 95 ]; then
        lag_score=$((60 + (cpu_pct - 70) * 4 / 3))  # 60-95 points
    else
        lag_score=$((95 + (cpu_pct - 95)))  # 95-100 points
    fi
    
    # ADD I/O-Wait contribution (indicates blocking, not just computation)
    # I/O-Wait > 10% = significant blocking
    # I/O-Wait > 30% = severe blocking (responsive lag!)
    if [ "$iowait_pct" -gt 10 ]; then
        iowait_contribution=$((iowait_pct / 2))  # 5-15% I/O = 2.5-7.5 bonus points
        lag_score=$((lag_score + iowait_contribution))
    fi
    
    # OPTIONAL: Load Average supplement (detect process queueing)
    local num_cpus=$(nproc 2>/dev/null || echo 4)
    if [ "$lag_score" -gt 50 ] && [ -f /proc/loadavg ]; then
        read load_1min load_5min load_rest < /proc/loadavg 2>/dev/null
        if [ -n "$load_1min" ]; then
            load_int="${load_1min%.*}"
            [ -z "$load_int" ] && load_int=0
            
            excess_load=$((load_int - num_cpus))
            if [ "$excess_load" -gt 0 ]; then
                load_bonus=$((excess_load * 3))
                [ "$load_bonus" -gt 15 ] && load_bonus=15
                lag_score=$((lag_score + load_bonus))
            fi
        fi
    fi
    
    # Cap lag_score at 100
    [ "$lag_score" -gt 100 ] && lag_score=100
    [ "$lag_score" -lt 0 ] && lag_score=0
    
    echo "$lag_score"
}

get_ac_power() {
    # Determine if running on AC power (1=on AC, 0=on battery)
    # Optimized: check first battery only (most systems have just one)
    
    local bat_dir=$(ls -d /sys/class/power_supply/BAT* 2>/dev/null | head -1)
    if [ -n "$bat_dir" ] && [ -f "$bat_dir/status" ]; then
        local status=$(cat "$bat_dir/status" 2>/dev/null)
        case "$status" in
            Discharging) echo 0; return 0 ;;
            *) echo 1; return 0 ;;
        esac
    fi
    
    # Fallback: check AC adapter directly
    if [ -f /sys/class/power_supply/AC/online ]; then
        cat /sys/class/power_supply/AC/online 2>/dev/null || echo 1
        return 0
    fi
    
    # Fallback: assume AC power if we can't determine
    echo 1
}

usage() {
    echo "Usage: $0 {start|stop|status|run}" 1>&2
}

# ============================================================================
# Main daemon loop
# ============================================================================

run_loop() {
    # source common functions
    # tlp-func-base must be sourced first as it defines functions and constants
    for lib in @TLP_TLIB@/tlp-func-base @TLP_TLIB@/func.d/35-tlp-func-batt @TLP_TLIB@/func.d/10-tlp-func-cpu @TLP_TLIB@/func.d/05-tlp-func-pm; do
        . "$lib" || { echo "Failed to source $lib"; exit 1; }
    done

    # Load configuration directly (for standalone execution outside of tlp's context)
    # Source defaults and user config files
    if [ -f "@TLP_TLIB@/defaults.conf" ]; then
        . "@TLP_TLIB@/defaults.conf"
    fi
    if [ -f "/etc/tlp.conf" ]; then
        . "/etc/tlp.conf"
    fi
    # Source all config files in /etc/tlp.d/ directory
    for conf_file in /etc/tlp.d/*.conf; do
        if [ -f "$conf_file" ]; then
            . "$conf_file"
        fi
    done

    # Use constants from tlp-func-base, or fallback if not readonly
    # Note: Some constants may be readonly, so we use local variables as fallbacks
    _pp_sav=${PP_SAV:-2}      # power-saver profile constant
    _ps_bat=${PS_BAT:-1}      # battery state constant
    _pp_none=${PP_NONE:-255}  # invalid profile constant
    _pwrrunfile=${PWRRUNFILE:-/run/tlp/last_pwr}  # file with last profile
    _rundir=${RUNDIR:-/run/tlp}  # runtime directory

    # Check if dynamic saver is enabled
    SAV_DYNAMIC_ENABLE=${SAV_DYNAMIC_ENABLE:-0}
    [ "$SAV_DYNAMIC_ENABLE" = "1" ] || { echo "dyn-saver: disabled"; exit 0; }
    
    # Auto-detect or validate SAV profile
    # Check if the configured or auto-detected profile is supported
    if [ -f /sys/firmware/acpi/platform_profile_choices ]; then
        if [ -n "$PLATFORM_PROFILE_ON_SAV" ]; then
            # Validate configured profile exists
            if ! grep -q "$PLATFORM_PROFILE_ON_SAV" /sys/firmware/acpi/platform_profile_choices 2>/dev/null; then
                # Configured profile not supported, try alternatives
                PLATFORM_PROFILE_ON_SAV=""
            fi
        fi
        
        # If not set or not valid, try preferred candidates in order
        if [ -z "$PLATFORM_PROFILE_ON_SAV" ]; then
            for candidate in quiet low-power cool; do
                if grep -q "$candidate" /sys/firmware/acpi/platform_profile_choices 2>/dev/null; then
                    PLATFORM_PROFILE_ON_SAV="$candidate"
                    echo "dyn-saver: auto-detected SAV profile: $PLATFORM_PROFILE_ON_SAV" >> /tmp/dyn-saver.log
                    break
                fi
            done
        fi
    fi
    
    # Require a supported profile to proceed
    if [ -z "$PLATFORM_PROFILE_ON_SAV" ]; then
        echo "dyn-saver: no supported platform profile found (quiet, low-power, or cool)"
        exit 1
    fi
    
    INTERVAL=${SAV_DYNAMIC_INTERVAL:-4}
    SAMPLES=${SAV_DYNAMIC_SAMPLES:-3}
    LAG_THRESH="${SAV_DYNAMIC_LAG_THRESHOLDS:-35,75}"
    HYST=${SAV_DYNAMIC_HYSTERESIS:-8}
    MIND=${SAV_DYNAMIC_MIN_DELAY:-4}

    thr_low=$(echo "$LAG_THRESH" | cut -d, -f1)
    thr_high=$(echo "$LAG_THRESH" | cut -d, -f2)
    [ -n "$thr_low" ] || thr_low=35
    [ -n "$thr_high" ] || thr_high=75

    # debug: verify constants are defined
    echo "dyn-saver: SAV_DYNAMIC_ENABLE=$SAV_DYNAMIC_ENABLE PLATFORM_PROFILE_ON_SAV=$PLATFORM_PROFILE_ON_SAV" >> /tmp/dyn-saver.log
    echo "dyn-saver: INTERVAL=$INTERVAL SAMPLES=$SAMPLES LAG_THRESHOLDS=$thr_low,$thr_high HYST=$HYST MIND=$MIND MODE=LAG_SCORE" >> /tmp/dyn-saver.log

    last_state="unknown"
    last_change=0
    last_ac_check=0
    cached_ac_status=1
    sample_buf=""
    sav_profile="$PLATFORM_PROFILE_ON_SAV"  # Store original SAV profile
    prev_avg=0
    last_sample_time=$(date +%s)
    current_interval=$INTERVAL

    while true; do
        now=$(date +%s)
        
        # Check AC status every 2*INTERVAL to reduce I/O (optimization: cache status)
        if [ $((now - last_ac_check)) -ge $((INTERVAL * 2)) ]; then
            last_ac_check=$now
            cached_ac_status=$(get_ac_power)
        fi
        
        if [ "$cached_ac_status" = "1" ]; then
            echo "dyn-saver: switched to AC mode, stopping" >> /tmp/dyn-saver.log
            exit 0
        fi

        # check last applied profile
        # Read current platform profile from /sys and compare with configured SAV value
        if [ -f /sys/firmware/acpi/platform_profile ]; then
            current_profile=$(cat /sys/firmware/acpi/platform_profile 2>/dev/null)
            
            # Check if current profile matches the configured SAV profile
            # We need to compare the actual profile name, not numeric values
            if [ "$current_profile" != "$PLATFORM_PROFILE_ON_SAV" ] && [ -n "$PLATFORM_PROFILE_ON_SAV" ]; then
                echo "dyn-saver: profile switched to '$current_profile', stopping" >> /tmp/dyn-saver.log
                exit 0
            fi
        else
            echo "dyn-saver: platform_profile not available, stopping" >> /tmp/dyn-saver.log
            exit 0
        fi

        # sample lag indicator and maintain moving average
        # Use lag detection based on CPU utilization, load average, and scheduler metrics
        pct=$(get_lag_score)
        
        sample_buf="$sample_buf $pct"
        # keep only last SAMPLES values
        set -- $sample_buf
        count=$#
        if [ $count -gt $SAMPLES ]; then
            # drop oldest
            shift_count=$((count - SAMPLES))
            i=0; newbuf=""
            for val in "$@"; do
                i=$((i+1))
                if [ $i -gt $shift_count ]; then
                    newbuf="$newbuf $val"
                fi
            done
            sample_buf="$newbuf"
        fi
        # compute average
        sum=0; n=0
        for v in $sample_buf; do sum=$((sum+v)); n=$((n+1)); done
        avg=0
        if [ $n -gt 0 ]; then avg=$((sum / n)); fi

        # Adaptive interval based on load trend
        # Calculate slope: how fast is load changing?
        time_delta=$((now - last_sample_time))
        delta_avg=$((avg - prev_avg))
        
        # Default to base interval
        current_interval=$INTERVAL
        
        # If lag is rising sharply, sample more frequently
        if [ $delta_avg -gt 20 ]; then
            # Lag jumping up rapidly - sample every 1 second (urgent)
            current_interval=1
        elif [ $delta_avg -gt 10 ]; then
            # Lag rising moderately - sample every 2 seconds
            current_interval=2
        elif [ $delta_avg -gt 5 ]; then
            # Lag rising slightly - sample every 3 seconds
            current_interval=3
        elif [ $delta_avg -lt -15 ]; then
            # Lag dropping sharply - can check slower
            current_interval=$((INTERVAL + 2))
        fi
        
        # Predictive: if close to high threshold and rising, sample faster
        threshold_distance=$((thr_high - HYST - avg))
        if [ $threshold_distance -gt 0 ] && [ $threshold_distance -le 20 ] && [ $delta_avg -gt 0 ]; then
            # Within 20 points of high lag threshold and rising - urgent sampling
            current_interval=1
        fi
        
        # Also check low threshold approaching from below
        low_threshold_distance=$((avg - (thr_low - HYST)))
        if [ $low_threshold_distance -gt -20 ] && [ $low_threshold_distance -le 0 ] && [ $delta_avg -lt 0 ]; then
            # Within 20 points below low lag threshold and falling - urgent sampling
            current_interval=1
        fi
        
        prev_avg=$avg
        last_sample_time=$now

        # determine target state with hysteresis
        target=unknown
        if [ "$avg" -le $((thr_low - HYST)) ]; then
            target=low
        elif [ "$avg" -ge $((thr_high + HYST)) ]; then
            target=high
        else
            target=med
        fi

        now=$(date +%s)
        changed=0
        if [ "$target" != "$last_state" ] && [ $((now - last_change)) -ge $MIND ]; then
            changed=1
        fi

        if [ $changed -eq 1 ]; then
            # Within the power-saver profile, adjust parameters based on workload lag
            # Note: We are NOT switching profiles, only adjusting PLATFORM_PROFILE_ON_SAV,
            # CPU_ENERGY_PERF_POLICY_ON_SAV, and PCIE_ASPM_ON_SAV within the SAV context
            case "$target" in
                low)
                    sav_platform_setting="$sav_profile"
                    sav_cpu_setting="power"
                    sav_pcie_setting="powersupersave"
                    ;;
                med)
                    sav_platform_setting="balanced"
                    sav_cpu_setting="balance_power"
                    sav_pcie_setting="powersave"
                    ;;
                high)
                    sav_platform_setting="performance"
                    sav_cpu_setting="balance_performance"
                    sav_pcie_setting="default"
                    ;;
            esac

            # Apply by temporarily setting *_ON_SAV vars and invoking setters
            # These setters will use our temporary values within the power-saver mode
            CPU_ENERGY_PERF_POLICY_ON_SAV="$sav_cpu_setting"
            PCIE_ASPM_ON_SAV="$sav_pcie_setting"
            PLATFORM_PROFILE_ON_SAV="$sav_platform_setting"

            # Call setters (they will check ppd and availability)
            set_cpu_perf_policy "$_pp_sav"
            set_pcie_aspm "$_pp_sav"
            set_platform_profile "$_pp_sav"

            last_state="$target"
            last_change=$now
            echo "dyn-saver: state=$target avg=$avg applied: $sav_platform_setting,$sav_cpu_setting,$sav_pcie_setting" >> /tmp/dyn-saver.log
        fi

        sleep "$current_interval"
    done
}

# ============================================================================
# Main program - only execute if invoked directly (not sourced)
# ============================================================================

# Prevent execution when this file is sourced by `tlp` (func.d/* are sourced).
# Only run the following when the script is invoked directly.
script_name="$(basename "$0")"
if [ "$script_name" = "35-tlp-func-dyn-saver" ] || [ "$script_name" = "tlp-func-dyn-saver" ]; then
    case "$1" in
        start)
            RUNDIR=/run/tlp
            if is_running; then
                echo "dyn-saver already running"
                exit 0
            fi
            rm -f /tmp/dyn-saver.log
            run_loop &
            create_pidfile $!
            echo "dyn-saver started (PID=$!)"
            ;;
        stop)
            RUNDIR=/run/tlp
            if ! is_running; then
                echo "dyn-saver not running"
                exit 0
            fi
            pid=$(cat "$RUNDIR/tlp-dyn-saver.pid")
            kill "$pid" 2>/dev/null || true
            remove_pidfile
            echo "dyn-saver stopped"
            ;;
        status)
            RUNDIR=/run/tlp
            if is_running; then
                echo "dyn-saver running"
                exit 0
            else
                echo "dyn-saver not running"
                exit 1
            fi
            ;;
        run)
            RUNDIR=/run/tlp
            run_loop
            ;;
        *)
            usage
            exit 2
            ;;
    esac
fi